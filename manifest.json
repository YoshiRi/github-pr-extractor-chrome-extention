{
  "manifest_version": 3,
  "name": "GitHub PR Extractor",
  "version": "1.0",
  "description": "Extract PR description and diff",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
     "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon_square_16.png",
    "48": "icons/icon_square_48.png",
    "128": "icons/icon_square_128.png"
  }
}